{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "duocode-retail",
  "title": "DuoCode Retail Schema",
  "description": "Schema for Malaysian retail shop business websites. Extends base with products, brands, and promotions.",
  "allOf": [
    { "$ref": "./_base.schema.json" },
    {
      "type": "object",
      "required": ["products", "brands", "promotions"],
      "properties": {
        "products": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "description", "price"],
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" },
              "price": { "type": "string" },
              "image": { "type": "string" },
              "category": { "type": "string" }
            }
          }
        },
        "brands": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "logo": { "type": "string" }
            }
          }
        },
        "promotions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["title", "description"],
            "properties": {
              "title": { "type": "string" },
              "description": { "type": "string" },
              "validUntil": { "type": "string" }
            }
          }
        }
      }
    }
  ]
}
