{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "duocode-beauty",
  "title": "DuoCode Beauty Schema",
  "description": "Schema for Malaysian beauty salon and spa business websites. Extends base with services, booking URL, and pricing tiers.",
  "allOf": [
    { "$ref": "./_base.schema.json" },
    {
      "type": "object",
      "required": ["services", "pricingTiers"],
      "properties": {
        "services": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["category", "items"],
            "properties": {
              "category": { "type": "string" },
              "items": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["name", "description", "price"],
                  "properties": {
                    "name": { "type": "string" },
                    "description": { "type": "string" },
                    "price": { "type": "string" },
                    "duration": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "bookingUrl": {
          "type": "string",
          "description": "URL for online booking (optional)"
        },
        "pricingTiers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["tier", "priceRange", "description"],
            "properties": {
              "tier": { "type": "string" },
              "priceRange": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        }
      }
    }
  ]
}
