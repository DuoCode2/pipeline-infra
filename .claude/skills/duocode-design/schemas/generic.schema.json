{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "duocode-generic",
  "title": "DuoCode Generic Schema",
  "description": "Schema for Malaysian businesses that do not fit a specific industry vertical. Extends base with features and highlights.",
  "allOf": [
    { "$ref": "./_base.schema.json" },
    {
      "type": "object",
      "required": ["features", "highlights"],
      "properties": {
        "features": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["title", "description"],
            "properties": {
              "title": { "type": "string" },
              "description": { "type": "string" },
              "icon": { "type": "string" }
            }
          }
        },
        "highlights": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Key business highlights or selling points"
        }
      }
    }
  ]
}
