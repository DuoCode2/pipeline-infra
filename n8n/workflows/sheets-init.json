        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "googleSheetsOAuth2Api",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\"values\":[[\"place_id\",\"name\",\"slug\",\"industry\",\"address\",\"phone\",\"rating\",\"reviews_count\",\"maps_url\",\"status\",\"qa_score\",\"url\",\"github_repo\",\"created_at\"]]}",
