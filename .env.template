# ═══════════════════════════════════════════════════════
# DuoCode Pipeline — Environment Variables
# cp .env.template .env && fill in your keys
# ═══════════════════════════════════════════════════════

# ── Google Cloud ──────────────────────────────────────
# Console: https://console.cloud.google.com/apis/credentials
# Enable: Places API (New), Generative Language API (Gemini)
GOOGLE_API_KEY=

# ── Google Sheets ─────────────────────────────────────
# Create sheet, copy ID from URL: docs.google.com/spreadsheets/d/{ID}/edit
# Sheets: "Leads" (19 cols) + "WorkLog" (6 cols)
GOOGLE_SHEETS_ID=

# ── Unsplash API ──────────────────────────────────────
# https://unsplash.com/oauth/applications
UNSPLASH_ACCESS_KEY=
UNSPLASH_SECRET_KEY=

# ── Pexels API ────────────────────────────────────────
# https://www.pexels.com/api/new/
PEXELS_API_KEY=

# ── Vercel ────────────────────────────────────────────
# https://vercel.com/account/tokens (Full Access scope)
VERCEL_TOKEN=

# ── n8n ───────────────────────────────────────────────
# Owner account for n8n UI login at localhost:5678
N8N_OWNER_EMAIL=
N8N_OWNER_PASSWORD=
N8N_LICENSE_KEY=

# ── Telegram Bot ──────────────────────────────────────
# @BotFather → /newbot → get token, then message bot to get chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Evolution API (Phase 5: WhatsApp) ─────────────────
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=
