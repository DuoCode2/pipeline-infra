# ═══════════════════════════════════════
# DuoCode Pipeline — Environment Variables
# ═══════════════════════════════════════

# ── REQUIRED (pipeline won't work without these) ──
GOOGLE_API_KEY=your_google_maps_api_key
UNSPLASH_ACCESS_KEY=your_unsplash_access_key
VERCEL_TOKEN=your_vercel_token

# ── OPTIONAL: Notifications ──
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── OPTIONAL: n8n integration ──
# N8N_WEBHOOK_URL=http://localhost:5678/webhook/log-work
# N8N_BASE_URL=http://localhost:5678
# N8N_API_KEY=your_n8n_api_key

# ── OPTIONAL: Vercel Team scope (deploys to team instead of personal) ──
# VERCEL_SCOPE=duocodetech

# ── OPTIONAL: Git identity (defaults: LiuWei / DuoCode2) ──
# GIT_OWNER=DuoCode2
# GIT_USER_NAME=LiuWei
# GIT_USER_EMAIL=sunflowers0607@outlook.com

# ── OPTIONAL: n8n Orchestration ──
# Only needed if running n8n (cd n8n && docker compose up -d)
N8N_OWNER_EMAIL=your_email
N8N_OWNER_PASSWORD=your_password
N8N_LICENSE_KEY=your_n8n_license_key
GOOGLE_SHEETS_ID=your_sheets_id

# ── FUTURE: WhatsApp Outreach (Phase 5) ──
# EVOLUTION_API_URL=http://localhost:8080
# EVOLUTION_API_KEY=your_evolution_api_key
