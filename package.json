{
  "name": "duocode-pipeline",
  "version": "1.0.0",
  "description": "DuoCode: Automated business website generation pipeline",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "vitest run",
    "test:unit": "vitest run tests/unit/",
    "test:integration": "vitest run tests/integration/",
    "test:e2e": "vitest run tests/e2e/",
    "test:coverage": "vitest run --coverage",
    "test:all": "vitest run && bash eval/run-all-evals.sh",
    "eval": "bash eval/run-all-evals.sh",
    "eval:skills": "bash eval/validate-skills.sh",
    "eval:quality": "bash eval/quality-metrics.sh",
    "eval:templates": "bash eval/validate-templates.sh",
    "eval:all": "bash eval/run-all-evals.sh",
    "generate": "npx tsx packages/pipeline/generate-site.ts",
    "discover": "npx tsx packages/discover/search.ts",
    "batch": "npx tsx packages/batch/orchestrate.ts",
    "batch:fallback": "npx tsx packages/batch/orchestrate.ts",
    "build:check": "npx tsc --noEmit",
    "n8n:check": "npx tsx packages/utils/n8n.ts health",
    "n8n:workflows": "npx tsx packages/utils/n8n.ts workflows",
    "n8n:executions": "npx tsx packages/utils/n8n.ts executions"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@googlemaps/google-maps-services-js": "^3.4.2",
    "autoprefixer": "^10.4.27",
    "culori": "^4.0.2",
    "dotenv": "^17.3.1",
    "next": "^14.2.35",
    "node-vibrant": "^4.0.4",
    "postcss": "^8.5.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@types/culori": "^4.0.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.1.1",
    "lighthouse": "^13.0.0",
    "serve": "^14.2.6",
    "svgo": "^4.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  }
}
